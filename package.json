{
  "name": "el-levert",
  "version": "1.0.0",
  "description": "Romanian version of Leveret by Neeve",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "clean": "npm run clean:windows && npm run clean:linux",
    "clean:windows": "node -e \"if (process.platform === 'win32') process.exit(1)\" || , if exist build rmdir /Q /S build",
    "clean:linux": "node -e \"if (process.platform !== 'win32') process.exit(1)\" || rm -rf build",
    "build": "eslint . --ext .ts && tsc --build",
    "start": "npm run build && node build/index.js",
    "lint": "eslint . --ext .ts",
    "prettier-format": "prettier --config .prettierrc 'src/**/*.ts' --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Alex31TheDev/el-levert.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Alex31TheDev/el-levert/issues"
  },
  "homepage": "https://github.com/Alex31TheDev/el-levert#readme",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "discord.js": "^14.14.1"
  }
}
